# Supabase Configuration (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Server Configuration
PORT=3000
NODE_ENV=development

# Twilio Configuration
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
OPENAI_API_KEY=your-openai-api-key-here
# Geoteknik Website Configuration
GEOTEKNIK_WEBSITE_URL=https://www.geoteknikltd.com/tr/
SCRAPE_ENABLED=true
SCRAPE_TIMEOUT=10000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/agent.log

# Agent Configuration
SILENCE_TIMEOUT_WELCOME=5000
SILENCE_TIMEOUT_TROUBLESHOOTING=10000
SILENCE_TIMEOUT_QUESTION=8000
SILENCE_TIMEOUT_ERROR=6000
MAX_SILENCE_RETRIES=3

# Feature Flags
ENABLE_WEB_SCRAPING=true
ENABLE_CONTEXT_CACHING=true
ENABLE_ANALYTICS=true
# Voice Agent Configuration
AGENT_NAME=Geoteknik-Support
VOICE_LATENCY_MS=30000
MAX_RESPONSE_WORDS=30
ENABLE_VERBAL_CUES=true
ENABLE_INTERRUPTION_HANDLING=true

# License Validation
LICENSE_API_URL=https://api.geoteknik.com/license
LICENSE_API_KEY=your_license_api_key_here

# Report Engine
REPORT_ENGINE_URL=https://api.geoteknik.com/reports
REPORT_TIMEOUT_MS=60000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/agent.log

# Environment
NODE_ENV=development
PORT=3000